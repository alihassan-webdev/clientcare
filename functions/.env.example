# Cloud Functions Configuration
# These variables control the behavior of Firebase Cloud Functions

# Sync Delay (milliseconds) - delay before recording sync metadata to prevent loops
SYNC_DELAY_MS=500

# Enable/Disable Specific Triggers
# Set to 'false' to disable bidirectional sync triggers (for debugging)
ENABLE_AUTH_TRIGGERS=true
ENABLE_FIRESTORE_TRIGGERS=true

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Protected UIDs (comma-separated)
# These UIDs will never be synced or deleted automatically
# Useful for protecting system admin accounts
# Example: PROTECTED_UIDS=uid1,uid2,uid3
PROTECTED_UIDS=

# Firestore Collection Names
# Usually don't need to change these unless you have custom requirements
USERS_COLLECTION=users
SYNC_METADATA_COLLECTION=syncMetadata
