rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // USERS COLLECTION - Core user data with status management
    // ============================================================
    match /users/{uid} {
      
      // Read Rules
      allow read: if 
        // Users can read their own document
        request.auth.uid == uid ||
        // Admins can read all users
        request.auth.token.admin == true ||
        // Service account / Cloud Functions can read for syncing
        request.auth == null;
      
      // Create Rules - Only Cloud Functions or explicit admin panel call
      allow create: if 
        // Cloud Functions (service account) can create
        request.auth == null ||
        // Admins can create via API
        request.auth.token.admin == true ||
        // Validate required fields when creating
        hasAllRequiredFields(request.resource.data);
      
      // Update Rules - Differentiated by source
      allow update: if 
        // Cloud Functions can update any field (sync operations)
        request.auth == null ||
        // Admins can update any field
        request.auth.token.admin == true ||
        // Users can update only safe fields in their own document
        (request.auth.uid == uid && isAllowedSelfUpdate(resource.data, request.resource.data));
      
      // Delete Rules
      allow delete: if 
        // Cloud Functions can delete (cleanup)
        request.auth == null ||
        // Admins can delete
        request.auth.token.admin == true;
    }
    
    // ============================================================
    // SYNC METADATA COLLECTION - Internal use only
    // ============================================================
    match /syncMetadata/{uid} {
      // Only Cloud Functions can access
      allow read, write, delete: if request.auth == null;
    }
    
    // ============================================================
    // DEFAULT - Block all other collections
    // ============================================================
    match /{document=**} {
      allow read, write, delete: if false;
    }
  }
  
  // ============================================================
  // HELPER FUNCTIONS
  // ============================================================
  
  // Check if all required fields are present for user creation
  function hasAllRequiredFields(data) {
    let requiredFields = ['uid', 'email', 'name', 'role', 'status', 'createdAt', 'updatedAt'];
    return data.keys().hasAll(requiredFields) &&
           data.uid is string &&
           data.email is string &&
           data.name is string &&
           data.role in ['admin', 'customer'] &&
           data.status in ['active', 'disabled'] &&
           data.createdAt is number &&
           data.updatedAt is number;
  }
  
  // Check if a user is allowed to update their own document
  // They can only update: name, email, phone, company
  // They CANNOT update: role, status, createdAt, updatedAt, uid
  function isAllowedSelfUpdate(oldData, newData) {
    let changedKeys = newData.diff(oldData).affectedKeys();
    let restrictedKeys = ['role', 'status', 'createdAt', 'updatedAt', 'uid', 'syncedWithAuth'];
    
    // Ensure no restricted fields are being modified
    let hasRestrictedChanges = changedKeys.hasAny(restrictedKeys);
    
    // Only allow if no restricted fields are changed
    return !hasRestrictedChanges &&
           // Validate field types for allowed updates
           (!newData.diff(oldData).affectedKeys().hasAny(['name']) || newData.name is string) &&
           (!newData.diff(oldData).affectedKeys().hasAny(['email']) || newData.email is string) &&
           (!newData.diff(oldData).affectedKeys().hasAny(['phone']) || newData.phone is string) &&
           (!newData.diff(oldData).affectedKeys().hasAny(['company']) || newData.company is string);
  }
}
